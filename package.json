{
  "name": "datapack",
  "version": "2.1.2",
  "description": "A high-performance JavaScript library for packing and unpacking binary data with a schema-based approach. Optimized for both Node.js and browser environments, datapack provides a simple and efficient way to serialize and deserialize complex data structures.",
  "keywords": [
    "pack",
    "unpack",
    "binary",
    "package",
    "proto",
    "buffer",
    "schema"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "browser": "dist/index.umd.js",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "ts-mocha -p tsconfig.test.json src/**/*.spec.ts",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags",
    "coverage": "nyc --exclude src/**/*.spec.ts ts-mocha -p tsconfig.test.json src/**/*.spec.ts",
    "benchmark": "ts-mocha -p tsconfig.test.json benchmark/benchmark.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmhung1210/datapack.git"
  },
  "author": "nmhung1210",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nmhung1210/datapack/issues"
  },
  "homepage": "https://github.com/nmhung1210/datapack#readme",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/mocha": "^9.1.0",
    "benchmark": "^2.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "expect": "^30.4.1",
    "nyc": "^17.1.0",
    "prettier": "^3.8.3",
    "rollup": "^2.80.0",
    "ts-mocha": "^9.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      },
      "browser": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.umd.js"
      },
      "default": "./dist/index.js"
    }
  }
}
